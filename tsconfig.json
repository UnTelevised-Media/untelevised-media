{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "types": [
      "jest",
      "node"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    // "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    // "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/c/*": [
        "./src/components/*"
      ],
      "@/l/*": [
        "./src/lib/*"
      ],
      "@/h/*": [
        "./src/hooks/*"
      ],
      "@/u/*": [
        "./src/util/*"
      ],
      "@/t/*": [
        "./src/models/types/*"
      ],
      "@/app/*": [
        "./src/app/*"
      ],
      "@/s/*": [
        "./src/server/*"
      ],
      "#/*": [
        "./*"
      ]
    },
    "ignoreDeprecations": "5.0",
    "rootDir": "./",
    "baseUrl": ".",
    "outDir": "./out",
    "typeRoots": [
      "./node_modules/@types",
      "./src/models/types"
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/lib/jest/jest.config.ts",
    "src/lib/jest/jest.setup.ts",
    "build-utilities/generateRobots.mjs",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
