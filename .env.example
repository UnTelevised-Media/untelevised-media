# =============================================================================
# UnTelevised Media — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Site URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PRODUCTION_URL=https://www.untelevised.media
NEXT_PUBLIC_DEVELOPMENT_URL=http://localhost:3000
NEXT_PUBLIC_METADATA_BASE_URL=https://www.untelevised.media
BASEURL=https://www.untelevised.media/

# -----------------------------------------------------------------------------
# Sanity CMS
# Project settings found at https://sanity.io/manage
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=articles
NEXT_PUBLIC_SANITY_API_VERSION=2025-06-04
NEXT_PUBLIC_SANITY_PROJECT_TITLE=UnTelevised Media

# Sanity API tokens — create at https://sanity.io/manage > API > Tokens
SANITY_API_READ_TOKEN=your_read_token
SANITY_API_WRITE_TOKEN=your_write_token
SANITY_REVALIDATE_SECRET=your_revalidate_secret

# Optional: for Sanity draft/preview mode
SANITY_PREVIEW_SECRET=your_preview_secret

# -----------------------------------------------------------------------------
# Google Analytics & Tag Manager
#
# IMPORTANT: These must use the NEXT_PUBLIC_ prefix — they are read by client
# components and embedded in the browser bundle.
#
# GTM_ID  — Google Tag Manager container ID (format: GTM-XXXXXX)
#            Found at tagmanager.google.com > Admin > Container ID
# GA4_ID  — GA4 Measurement ID (format: G-XXXXXXXXXX)
#            Found at analytics.google.com > Admin > Data Streams > Measurement ID
#            Only required if tracking GA4 events *outside* of GTM.
#            If GA4 is managed entirely inside the GTM container, leave blank.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GTM_ID=GTM-XXXXXX
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# Google AdSense
#
# GAS_ID  — AdSense Publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
#            Found at adsense.google.com > Account > Account information
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GAS_ID=ca-pub-XXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Sentry (optional — error monitoring)
# Found at sentry.io > Settings > Auth Tokens
# -----------------------------------------------------------------------------
SENTRY_AUTH_TOKEN=your_sentry_auth_token
