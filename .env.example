# =============================================================================
# UnTelevised Media — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Site URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PRODUCTION_URL=https://www.untelevised.media
NEXT_PUBLIC_DEVELOPMENT_URL=http://localhost:3000
NEXT_PUBLIC_METADATA_BASE_URL=https://www.untelevised.media
BASEURL=https://www.untelevised.media/

# -----------------------------------------------------------------------------
# Sanity CMS
# Project settings found at https://sanity.io/manage
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=articles
NEXT_PUBLIC_SANITY_API_VERSION=2025-06-04
NEXT_PUBLIC_SANITY_PROJECT_TITLE=UnTelevised Media

# Sanity API tokens — create at https://sanity.io/manage > API > Tokens
SANITY_API_READ_TOKEN=your_read_token
SANITY_API_WRITE_TOKEN=your_write_token   # Requires Editor role for view counter mutations (manage.sanity.io → API → Tokens)
SANITY_REVALIDATE_SECRET=your_revalidate_secret

# Optional: for Sanity draft/preview mode
SANITY_PREVIEW_SECRET=your_preview_secret

# -----------------------------------------------------------------------------
# Google Analytics & Tag Manager
#
# IMPORTANT: These must use the NEXT_PUBLIC_ prefix — they are read by client
# components and embedded in the browser bundle.
#
# GTM_ID  — Google Tag Manager container ID (format: GTM-XXXXXX)
#            Found at tagmanager.google.com > Admin > Container ID
# GA4_ID  — GA4 Measurement ID (format: G-XXXXXXXXXX)
#            Found at analytics.google.com > Admin > Data Streams > Measurement ID
#            Only required if tracking GA4 events *outside* of GTM.
#            If GA4 is managed entirely inside the GTM container, leave blank.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GTM_ID=GTM-XXXXXX
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# Google AdSense
#
# GAS_ID  — AdSense Publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
#            Found at adsense.google.com > Account > Account information
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GAS_ID=ca-pub-XXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Sentry (optional — error monitoring)
# Found at sentry.io > Settings > Auth Tokens
# -----------------------------------------------------------------------------
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# -----------------------------------------------------------------------------
# Algolia Search (https://dashboard.algolia.com → API Keys)
# -----------------------------------------------------------------------------
ALGOLIA_APP_ID=                         # Your Algolia App ID
ALGOLIA_ADMIN_API_KEY=                  # Admin API Key — SERVER ONLY, never expose to client
NEXT_PUBLIC_ALGOLIA_APP_ID=             # Same value as ALGOLIA_APP_ID — safe for client
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=     # Search-Only API Key — read-only, safe for client
SANITY_WEBHOOK_SECRET=                  # Secret for HMAC validation of Sanity webhooks

# -----------------------------------------------------------------------------
# Coral Comments (https://coralproject.net)
# Self-hosted Coral instance — deployed via Docker Compose on Hetzner VPS.
#
# NEXT_PUBLIC_CORAL_URL   — Public URL of your self-hosted Coral instance (no trailing slash)
# CORAL_SSO_SECRET        — 32+ char random secret shared between this Next.js app and
#                           Coral Admin (Configure → Authentication → SSO Key field).
#                           Generate with: openssl rand -base64 32
#                           SERVER ONLY — never prefix with NEXT_PUBLIC_
#                           Must be identical in Vercel env vars AND pasted into Coral Admin SSO.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CORAL_URL=https://coral.untelevised.media
CORAL_SSO_SECRET=                       # Generate: openssl rand -base64 32 — paste same value into Coral Admin → Configure → Authentication → SSO Key

# -----------------------------------------------------------------------------
# Newsletter emails (confirmation + welcome)
#
# Newsletter confirmation and welcome emails share the same Nodemailer SMTP
# transporter as bookstore order emails — no additional mail service needed.
# SMTP_HOST / SMTP_PORT / SMTP_SECURE / SMTP_USER / SMTP_PASS are configured
# under "EMAIL CONFIGURATION (Nodemailer)" above.
#
# NEXT_PUBLIC_SITE_URL — Canonical site URL used to build confirm/unsubscribe
#                        links in newsletter emails.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://untelevised.media

# -----------------------------------------------------------------------------
# Membership — Stripe (separate project from the bookstore Stripe account)
# Create a new project at https://dashboard.stripe.com under the same Stripe org.
# All keys MUST use the STRIPE_MEMBERSHIP_ prefix to avoid colliding with the
# bookstore keys (STRIPE_SECRET_KEY / STRIPE_PUBLISHABLE_KEY).
# -----------------------------------------------------------------------------
STRIPE_MEMBERSHIP_SECRET_KEY=sk_test_...          # Server-only, never expose to client
NEXT_PUBLIC_STRIPE_MEMBERSHIP_PUBLISHABLE_KEY=pk_test_...
STRIPE_MEMBERSHIP_WEBHOOK_SECRET=whsec_...        # Set as Supabase Edge Function secret
STRIPE_MEMBERSHIP_PRICE_SUPPORTER=price_...       # $5/month recurring price ID
STRIPE_MEMBERSHIP_PRICE_CONTRIBUTOR=price_...     # $15/month recurring price ID
STRIPE_MEMBERSHIP_PRICE_PATRON=price_...          # $50/month recurring price ID

# -----------------------------------------------------------------------------
# Membership — Supabase (separate project from SUPABASE_SHOP_*)
# Create at https://supabase.com, run the SQL migration from the issue #13 plan,
# then copy the project URL and keys below.
# -----------------------------------------------------------------------------
SUPABASE_MEMBERSHIP_URL=https://xxxx.supabase.co
SUPABASE_MEMBERSHIP_ANON_KEY=eyJ...
SUPABASE_MEMBERSHIP_SERVICE_ROLE_KEY=eyJ...
