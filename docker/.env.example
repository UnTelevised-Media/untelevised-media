# docker/.env.example
# Copy to docker/.env and fill in all values before running docker compose up.
# This file is safe to commit. docker/.env is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Coral instance URL (no trailing slash)
# Must match the subdomain you point at this server.
# -----------------------------------------------------------------------------
CORAL_URL=https://coral.untelevised.media

# -----------------------------------------------------------------------------
# Allowed embedding origins — comma-separated, no trailing slashes.
# Add localhost:3000 for local dev if needed.
# -----------------------------------------------------------------------------
CORAL_ALLOWED_ORIGINS=https://untelevised.live,https://www.untelevised.live,https://untelevised.media,https://www.untelevised.media,localhost:3000

# -----------------------------------------------------------------------------
# Coral internal signing secret — used by Coral itself for its own JWTs.
# Generate: openssl rand -base64 32
# NOTE: This is NOT the same as CORAL_SSO_SECRET in your Next.js .env.local.
#       CORAL_SIGNING_SECRET is Coral's own internal secret.
#       CORAL_SSO_SECRET (in Next.js) must be pasted into Coral Admin → SSO.
# -----------------------------------------------------------------------------
CORAL_SIGNING_SECRET=                   # Generate: openssl rand -base64 32

# -----------------------------------------------------------------------------
# Email / SMTP — required for password resets and comment notifications.
# If using Postmark, SendGrid, Mailgun etc, use their SMTP bridge credentials.
# -----------------------------------------------------------------------------
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=                    # your Gmail address
EMAIL_SMTP_PASSWORD=                    # Google App Password (NOT your Gmail login) — myaccount.google.com/security → App passwords
EMAIL_SMTP_SECURE=false
EMAIL_FROM_ADDRESS=                     # the Gmail address you send from

# -----------------------------------------------------------------------------
# Google Perspective API — AI-powered toxicity detection (optional but recommended)
# Get a key at: https://developers.google.com/codelabs/setup-perspective-api
# -----------------------------------------------------------------------------
PERSPECTIVE_API_KEY=

# -----------------------------------------------------------------------------
# Backup retention — how many days of nightly dumps to keep
# -----------------------------------------------------------------------------
BACKUP_RETAIN_DAYS=14
